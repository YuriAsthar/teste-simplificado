<?xml version="1.0"?>
<ruleset name="Laravel PHPMD Ruleset"
         xmlns="http://pmd.sf.net/ruleset/1.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sf.net/ruleset/1.0.0 http://pmd.sf.net/ruleset_xml_schema.xsd"
         xsi:noNamespaceSchemaLocation="http://pmd.sf.net/ruleset_xml_schema.xsd">
    <description>Custom PHPMD ruleset for this Laravel project.</description>

    <rule ref="rulesets/cleancode.xml" />
    <rule ref="rulesets/codesize.xml" />
    <rule ref="rulesets/controversial.xml" />
    <rule ref="rulesets/design.xml" />
    <rule ref="rulesets/naming.xml" />
    <rule ref="rulesets/unusedcode.xml" />

    <!-- PHPUnit test methods commonly use snake_case names. -->
    <rule ref="rulesets/controversial.xml/CamelCaseMethodName">
        <exclude-pattern>tests/*</exclude-pattern>
    </rule>

    <!-- Laravel factories commonly use facades and helpers that PHPMD flags as static access. -->
    <rule ref="rulesets/cleancode.xml/StaticAccess">
        <exclude-pattern>database/factories/*</exclude-pattern>
    </rule>

    <!-- Factory callbacks (e.g. state(fn (array $attributes) => ...)) receive parameters that are not always referenced. -->
    <rule ref="rulesets/unusedcode.xml/UnusedFormalParameter">
        <exclude-pattern>database/factories/*</exclude-pattern>
    </rule>
</ruleset>
