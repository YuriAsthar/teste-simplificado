parameters:
	ignoreErrors:
		-
			message: '#^Call to method PHPUnit\\Framework\\Assert\:\:assertTrue\(\) with true will always evaluate to true\.$#'
			identifier: method.alreadyNarrowedType
			count: 1
			path: tests/Unit/ExampleTest.php

		-
			message: '#^Call to an undefined method Mockery\\ExpectationInterface\|Mockery\\HigherOrderMessage\:\:once\(\)\.$#'
			identifier: method.notFound
			count: 9
			path: tests/Unit/Services/KafkaTransferProcessorTest.php

		-
			message: '#^Call to an undefined method App\\Contracts\\TransferPublisherInterface\:\:shouldReceive\(\)\.$#'
			identifier: method.notFound
			count: 1
			path: tests/Unit/Services/KafkaTransferServiceTest.php

		-
			message: '#^Call to an undefined method Illuminate\\Contracts\\Bus\\Dispatcher\:\:shouldReceive\(\)\.$#'
			identifier: method.notFound
			count: 2
			path: tests/Unit/Services/KafkaTransferServiceTest.php

		-
			message: '#^Call to an undefined method Illuminate\\Contracts\\Cache\\Repository\:\:shouldReceive\(\)\.$#'
			identifier: method.notFound
			count: 6
			path: tests/Unit/Services/KafkaTransferServiceTest.php

		-
			message: '#^Call to an undefined method Mockery\\ExpectationInterface\|Mockery\\HigherOrderMessage\:\:once\(\)\.$#'
			identifier: method.notFound
			count: 14
			path: tests/Unit/Services/TransferMessageConsumerTest.php

		-
			message: '#^Call to an undefined method Mockery\\ExpectationInterface\|Mockery\\HigherOrderMessage\:\:once\(\)\.$#'
