			identifier: method.notFound
			count: 2
			path: tests/Unit/Services/TransferRetryPolicyTest.php

		-
			message: '#^Call to an undefined method Mockery\\ExpectationInterface\|Mockery\\HigherOrderMessage\:\:once\(\)\.$#'
			identifier: method.notFound
			count: 6
			path: tests/Unit/Services/WalletTransferServiceTest.php

		-
			message: '#^Parameter \#1 \$authorizer of class App\\Services\\WalletTransferService constructor expects App\\Services\\AuthorizerClient, Mockery\\MockInterface given\.$#'
